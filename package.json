    "check:demo": "tsx scripts/check-demo.ts",
    "validate": "tsx scripts/validate.ts",
    "test": "tsx scripts/test.ts",
    "aso": "tsx scripts/aso.ts"
  },
  "devDependencies": {
    "@types/fs-extra": "latest",
    "@types/node": "latest",
    "eslint": "latest",
